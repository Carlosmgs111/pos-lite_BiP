---
import type { StateMachine } from '../../types/logbook';

interface Props {
  machine: StateMachine;
}

const { machine } = Astro.props;
---

<div class="border border-gray-200 rounded-lg overflow-hidden bg-white">
  <div class="px-4 py-2 bg-gray-50 border-b border-gray-200">
    <h4 class="text-sm font-bold text-gray-900">{machine.entity}</h4>
    <div class="flex gap-1.5 mt-1.5">
      {machine.states.map((state) => (
        <span class="text-xs font-mono px-1.5 py-0.5 rounded bg-gray-100 text-gray-600">{state}</span>
      ))}
    </div>
  </div>
  <div class="px-4 py-2 space-y-1.5">
    {machine.transitions.map((t) => (
      <div class="flex items-center gap-2 text-xs">
        <span class="font-mono font-bold text-gray-700">{t.from}</span>
        <span class="text-gray-400">→</span>
        <span class="font-mono font-bold text-gray-700">{t.to}</span>
        <span class="text-gray-400 ml-auto">{t.trigger}</span>
      </div>
    ))}
  </div>
</div>
