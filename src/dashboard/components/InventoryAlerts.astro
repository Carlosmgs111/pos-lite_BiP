---
interface Product {
  name: string;
  stock: number;
  reserved: number;
  status: 'low' | 'out' | 'reserved';
}

const products: Product[] = [
  { name: 'Café Americano', stock: 5, reserved: 3, status: 'low' },
  { name: 'Cappuccino', stock: 0, reserved: 0, status: 'out' },
  { name: 'Latte Vainilla', stock: 8, reserved: 5, status: 'reserved' },
  { name: 'Mocha', stock: 3, reserved: 2, status: 'low' },
  { name: 'Té Verde', stock: 0, reserved: 0, status: 'out' },
];

const statusConfig: Record<string, { label: string; color: string; icon: string }> = {
  low: { label: 'Stock bajo', color: 'text-amber-600 bg-amber-50', icon: '!' },
  out: { label: 'Sin stock', color: 'text-red-600 bg-red-50', icon: '×' },
  reserved: { label: 'Reservado', color: 'text-blue-600 bg-blue-50', icon: 'R' },
};
---

<div class="bg-white rounded-xl border border-gray-200 p-5">
  <div class="flex items-center justify-between mb-4">
    <div>
      <h3 class="text-lg font-semibold text-gray-900">Alertas de inventario</h3>
      <p class="text-sm text-gray-500 mt-1">Productos que requieren atención</p>
    </div>
    <span class="text-xs font-medium px-2.5 py-1 rounded-full bg-red-50 text-red-700">
      {products.length} alertas
    </span>
  </div>

  <div class="space-y-3">
    {products.map((product) => {
      const config = statusConfig[product.status];
      return (
        <div class="flex items-center justify-between p-3 rounded-lg border border-gray-100 hover:border-gray-200 transition-colors">
          <div class="flex items-center gap-3">
            <span class={`w-8 h-8 rounded-full ${config.color} flex items-center justify-center text-sm font-bold`}>
              {config.icon}
            </span>
            <div>
              <p class="text-sm font-medium text-gray-900">{product.name}</p>
              <p class="text-xs text-gray-500">{config.label}</p>
            </div>
          </div>
          <div class="text-right">
            <p class="text-sm font-medium text-gray-900">{product.stock} uds</p>
            {product.reserved > 0 && (
              <p class="text-xs text-blue-600">{product.reserved} reservadas</p>
            )}
          </div>
        </div>
      );
    })}
  </div>

  <div class="mt-4 pt-4 border-t border-gray-100">
    <div class="grid grid-cols-3 gap-4 text-center">
      <div>
        <p class="text-lg font-bold text-gray-900">{products.filter(p => p.status === 'out').length}</p>
        <p class="text-xs text-gray-500">Sin stock</p>
      </div>
      <div>
        <p class="text-lg font-bold text-amber-600">{products.filter(p => p.status === 'low').length}</p>
        <p class="text-xs text-gray-500">Stock bajo</p>
      </div>
      <div>
        <p class="text-lg font-bold text-blue-600">{products.filter(p => p.status === 'reserved').length}</p>
        <p class="text-xs text-gray-500">Reservados</p>
      </div>
    </div>
  </div>
</div>
