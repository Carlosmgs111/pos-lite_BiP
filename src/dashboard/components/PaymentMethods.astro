---
interface PaymentMethod {
  name: string;
  count: number;
  amount: number;
  percentage: number;
  color: string;
}

const methods: PaymentMethod[] = [
  { name: 'Efectivo', count: 28, amount: 687.50, percentage: 55, color: 'bg-emerald-500' },
  { name: 'Tarjeta', count: 15, amount: 445.20, percentage: 30, color: 'bg-blue-500' },
  { name: 'Transferencia', count: 4, amount: 115.80, percentage: 15, color: 'bg-violet-500' },
];

const total = methods.reduce((sum, m) => sum + m.amount, 0);
---

<div class="bg-white rounded-xl border border-gray-200 p-5">
  <div class="mb-6">
    <h3 class="text-lg font-semibold text-gray-900">Métodos de pago</h3>
    <p class="text-sm text-gray-500 mt-1">Distribución por tipo de pago</p>
  </div>

  <!-- Donut chart -->
  <div class="flex items-center justify-center mb-6">
    <div class="relative w-40 h-40">
      <svg viewBox="0 0 36 36" class="w-full h-full -rotate-90">
        {methods.reduce((acc, method, i) => {
          const offset = acc.offset;
          acc.offset += method.percentage;
          acc.elements.push(
            <circle
              cx="18"
              cy="18"
              r="15.915"
              fill="none"
              stroke-width="3"
              class={method.color.replace('bg-', 'stroke-')}
              stroke-dasharray={`${method.percentage} ${100 - method.percentage}`}
              stroke-dashoffset={-offset}
              stroke-linecap="round"
            />
          );
          return acc;
        }, { offset: 0, elements: [] as any[] }).elements}
      </svg>
      <div class="absolute inset-0 flex flex-col items-center justify-center">
        <p class="text-xl font-bold text-gray-900">${total.toFixed(0)}</p>
        <p class="text-xs text-gray-500">Total</p>
      </div>
    </div>
  </div>

  <!-- Legend -->
  <div class="space-y-3">
    {methods.map((method) => (
      <div class="flex items-center justify-between">
        <div class="flex items-center gap-3">
          <span class={`w-3 h-3 rounded-full ${method.color}`}></span>
          <div>
            <p class="text-sm font-medium text-gray-900">{method.name}</p>
            <p class="text-xs text-gray-500">{method.count} transacciones</p>
          </div>
        </div>
        <div class="text-right">
          <p class="text-sm font-medium text-gray-900">${method.amount.toFixed(2)}</p>
          <p class="text-xs text-gray-500">{method.percentage}%</p>
        </div>
      </div>
    ))}
  </div>
</div>
