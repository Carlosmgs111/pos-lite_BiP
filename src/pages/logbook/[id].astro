---
import { getCollection, render } from 'astro:content';
import Layout from '../../shared/layouts/Layout.astro';
import TestSuiteCard from '../../logbook/components/TestSuiteCard.astro';
import EntryNavigation from '../../logbook/components/EntryNavigation.astro';
import BoundedContextMap from '../../logbook/components/ddd/BoundedContextMap.astro';
import DomainEventCard from '../../logbook/components/ddd/DomainEventCard.astro';
import StateMachineCard from '../../logbook/components/ddd/StateMachineCard.astro';
import { resolveTestResults } from '../../logbook/lib/resolve-tests';
import type { LogbookArtifacts } from '../../logbook/types/logbook';
import { t } from '../../shared/i18n';

const artifactModules = import.meta.glob('../../logbook/data/artifacts/*.ts', { eager: true });

export async function getStaticPaths() {
  const entries = await getCollection('logbook');
  const sorted = entries.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
  return sorted.map((entry, i) => ({
    params: { id: entry.id },
    props: {
      entry,
      prev: sorted[i + 1] ? { id: sorted[i + 1].id, title: sorted[i + 1].data.title } : null,
      next: sorted[i - 1] ? { id: sorted[i - 1].id, title: sorted[i - 1].data.title } : null,
    },
  }));
}

const { entry, prev, next } = Astro.props;
const { Content } = await render(entry);

const artifactKey = Object.keys(artifactModules).find((k) => k.endsWith(`/${entry.id}.ts`));
const artifacts: LogbookArtifacts | null = artifactKey
  ? (artifactModules[artifactKey] as { artifacts: LogbookArtifacts }).artifacts
  : null;

const testResults = await resolveTestResults(entry.id, entry.data.testSuites, entry.data.closed);

const startDateStr = entry.data.date.toISOString().split('T')[0];
const closedDateStr = entry.data.closed
  ? (entry.data.closedDate ?? entry.data.date).toISOString().split('T')[0]
  : new Date().toISOString().split('T')[0];
---

<Layout title={`${entry.data.title} - pos-lite`}>
  <div class="max-w-3xl mx-auto px-4 py-8">
    {/* Header */}
    <header class="mb-8">
      <div class="flex items-center gap-2">
        <time class="text-sm font-mono text-gray-400">{startDateStr}</time>
        {entry.data.closed && entry.data.closedDate && (
          <span class="text-sm text-gray-300">→</span>
          <time class="text-sm font-mono text-gray-400">{closedDateStr}</time>
        )}
        <span class={`text-xs font-medium px-1.5 py-0.5 rounded ${entry.data.closed ? 'bg-gray-100 text-gray-500' : 'bg-emerald-100 text-emerald-700'}`}>
          {entry.data.closed ? t.logbook.statusClosed : t.logbook.statusOpen}
        </span>
      </div>
      <h1 class="text-2xl font-bold text-gray-900 mt-1">{entry.data.title}</h1>
      {entry.data.tags.length > 0 && (
        <div class="flex flex-wrap gap-1 mt-3">
          {entry.data.tags.map((tag) => (
            <span class="text-xs font-medium px-2 py-0.5 rounded-full bg-gray-100 text-gray-600">{tag}</span>
          ))}
        </div>
      )}
    </header>

    {/* Sticky Section Nav */}
    <nav class="sticky top-10 z-10 bg-white/90 backdrop-blur-sm border-b border-gray-200 -mx-4 px-4 py-2 mb-8">
      <div class="flex gap-2">
        <a href="#summary" class="text-xs font-medium px-3 py-1.5 rounded-full bg-blue-50 text-blue-700 hover:bg-blue-100 transition-colors">
          {t.logbook.navSummary}
        </a>
        {testResults.length > 0 && (
          <a href="#tests" class="text-xs font-medium px-3 py-1.5 rounded-full bg-emerald-50 text-emerald-700 hover:bg-emerald-100 transition-colors">
            {t.logbook.navTests}
          </a>
        )}
        {artifacts && (
          <a href="#artifacts" class="text-xs font-medium px-3 py-1.5 rounded-full bg-violet-50 text-violet-700 hover:bg-violet-100 transition-colors">
            {t.logbook.navArtifacts}
          </a>
        )}
      </div>
    </nav>

    {/* Description (markdown content) */}
    <article id="summary" class="mb-8 scroll-mt-24 border-l-4 border-blue-200 bg-blue-50/30 p-5 max-w-none [&_h2]:text-xl [&_h2]:font-bold [&_h2]:text-gray-900 [&_h2]:mt-6 [&_h2]:mb-3 [&_p]:text-gray-700 [&_p]:leading-relaxed [&_p]:mb-4 [&_strong]:font-bold [&_code]:font-mono [&_code]:text-sm [&_code]:bg-blue-100/50 [&_code]:px-1 [&_code]:rounded [&_ul]:list-disc [&_ul]:pl-6 [&_ul]:mb-4 [&_li]:text-gray-700 [&_li]:mb-1">
      <Content />
    </article>

    {/* Test Results */}
    {testResults.length > 0 && (
      <section id="tests" class="mb-8 scroll-mt-24 border-l-4 border-emerald-200 bg-emerald-50/30 p-5">
        <h2 class="text-lg font-bold text-gray-900 mb-4">Test Results</h2>
        <div class="space-y-4">
          {testResults.map((suite) => (
            <TestSuiteCard suiteResult={suite} />
          ))}
        </div>
      </section>
    )}

    {/* DDD Artifacts */}
    {artifacts && (
      <section id="artifacts" class="mb-8 scroll-mt-24 border-l-4 border-violet-200 bg-violet-50/30 p-5">
        <h2 class="text-lg font-bold text-gray-900 mb-4">DDD Artifacts</h2>
        <div class="space-y-6">
          <BoundedContextMap
            contexts={artifacts.boundedContexts}
            sharedVOs={artifacts.sharedValueObjects}
            ports={artifacts.ports}
          />

          {artifacts.domainEvents && artifacts.domainEvents.length > 0 && (
            <div>
              <h3 class="text-sm font-bold text-gray-600 uppercase tracking-wide mb-3">Domain Events</h3>
              <div class="space-y-2">
                {artifacts.domainEvents.map((event) => (
                  <DomainEventCard event={event} />
                ))}
              </div>
            </div>
          )}

          {artifacts.stateMachines && artifacts.stateMachines.length > 0 && (
            <div>
              <h3 class="text-sm font-bold text-gray-600 uppercase tracking-wide mb-3">State Machines</h3>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                {artifacts.stateMachines.map((machine) => (
                  <StateMachineCard machine={machine} />
                ))}
              </div>
            </div>
          )}
        </div>
      </section>
    )}

    <EntryNavigation prev={prev} next={next} />
  </div>
</Layout>
